{
  "extends": "../tsconfig-base.json",
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "noLib": true,
    "allowJs": false,
    "typeRoots": [ "types" ],
    "types": [ "assembly" ],
    "plugins": [ { "name": "toilscript/std/ts-plugin.cjs" } ],
    "paths": {
      "*": [
        "./assembly/*"
      ]
    }
  }
}
